{
  "name": "wavearea",
  "version": "1.1.0",
  "description": "Edit audio in textarea",
  "main": "index.js",
  "scripts": {
    "start": "esbuild ./src/index.jsx ./src/worker.js --jsx=automatic --jsx-factory=h --jsx-fragment=Fragment --jsx-import-source='preact' --bundle --splitting --sourcemap --loader:.svg=text --format=esm --outdir=dist --servedir=.",
    "build": "rm -rf ./dist/* && esbuild ./src/index.jsx ./src/worker.js --jsx-factory=h --jsx-fragment=Fragment --bundle --splitting --minify --sourcemap --loader:.svg=text --format=esm --outdir=dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dy/wavearea.git"
  },
  "keywords": [
    "audio",
    "web-audio",
    "waveform",
    "dsp",
    "wave player",
    "audio player",
    "audio edit"
  ],
  "author": "Dmitry Iv <dfcreative@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dy/wavearea/issues"
  },
  "homepage": "https://github.com/dy/wavearea#readme",
  "dependencies": {
    "@preact/signals": "^1.2.2",
    "audio-buffer": "^5.0.0",
    "audio-decode": "^2.2.0",
    "kv-storage-polyfill": "^2.0.0",
    "preact": "^10.19.3",
    "pseudo-worker": "^1.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.16.12"
  }
}
