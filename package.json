{
  "name": "wavearea",
  "version": "1.1.0",
  "description": "Edit audio in textarea",
  "main": "index.js",
  "scripts": {
    "start": "esbuild ./src/wavearea.js ./src/engine-worker.js --bundle --splitting --sourcemap --loader:.svg=text --loader:.html=text --loader:.woff2=file --format=esm --outdir=dist --servedir=. --external:@audio/aiff-decode --external:@audio/caf-decode --external:@audio/webm-decode --external:@audio/amr-decode --external:@audio/wma-decode --external:fs --external:fs/promises --external:url --external:node:worker_threads --external:@audio/speaker --external:@audio/mic --out-extension:.js=.js --entry-names=[name]",
    "build": "rm -rf ./dist/* && esbuild ./src/wavearea.js ./src/engine-worker.js --bundle --splitting --minify --sourcemap --loader:.svg=text --loader:.html=text --loader:.woff2=file --format=esm --outdir=dist --external:@audio/aiff-decode --external:@audio/caf-decode --external:@audio/webm-decode --external:@audio/amr-decode --external:@audio/wma-decode --external:fs --external:fs/promises --external:url --external:node:worker_threads --external:@audio/speaker --external:@audio/mic --entry-names=[name]",
    "test": "npm run test:unit && npx playwright test",
    "test:unit": "node test/unit/selection.test.js && node test/unit/virtual.test.js && node test/unit/adapter.test.js && node test/unit/store.test.js && node test/unit/waveform.test.js",
    "test:e2e": "npx playwright test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audio-lab/wavearea.git"
  },
  "keywords": [
    "audio",
    "web-audio",
    "waveform",
    "dsp",
    "wave player",
    "audio player",
    "audio edit"
  ],
  "author": "Dmitry Iv <dfcreative@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/audio-lab/wavearea/issues"
  },
  "homepage": "https://github.com/audio-lab/wavearea#readme",
  "dependencies": {
    "@audio/aac-decode": "^1.0.1",
    "audio": "^2.6.1",
    "sprae": "^13.4.0",
    "wavefont": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.16.12",
    "tst": "^9.2.2"
  }
}
